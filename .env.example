# ============================================================
# FEMME DIRECTORY — Environment Variables
# Copy this file to .env.local for local development
# Never commit .env.local to version control
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/femme_directory"

# ── Authentication ────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET="change-this-to-a-random-64-character-string-in-production"

# ── AWS S3 / Compatible Storage ───────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"

# Public bucket for profile images and gallery photos
S3_PUBLIC_BUCKET="femme-public"

# Private bucket for verification documents (ID, video)
S3_PRIVATE_BUCKET="femme-private"

# CDN URL for public assets (CloudFront, DigitalOcean CDN, etc.)
CDN_URL="https://femme-public.s3.amazonaws.com"

# For S3-compatible services (MinIO, DigitalOcean Spaces, Cloudflare R2)
# Leave empty to use AWS S3
# S3_ENDPOINT="https://nyc3.digitaloceanspaces.com"

# ── Next.js ──────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"

# ── Stripe (for premium listings — plug in when ready) ───────
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Redis (optional — for production rate limiting) ──────────
# REDIS_URL="redis://localhost:6379"

# ── Email (optional — for notifications) ─────────────────────
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="587"
# SMTP_USER="resend"
# SMTP_PASS="re_..."
# EMAIL_FROM="noreply@femmedirectory.com"
