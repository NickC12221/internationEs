generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MODEL
  AGENCY
  ADMIN
}

enum VerificationStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  TRAVELING
  BUSY
}

enum ListingTier {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(MODEL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile             Profile?
  agency              Agency?
  verificationRequest VerificationRequest?
  favorites           Favorite[]           @relation("UserFavorites")

  @@map("users")
}

model Agency {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  slug        String   @unique
  bio         String?  @db.Text
  website     String?
  instagram   String?
  phone       String?
  email       String?

  country     String
  countryCode String
  city        String
  citySlug    String

  logoUrl     String?

  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  subscriptionExpiresAt DateTime?

  isPremium   Boolean  @default(false)
  premiumExpiresAt DateTime?

  isActive    Boolean  @default(true)

  models      AgencyModel[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([countryCode, citySlug])
  @@index([isPremium])
  @@map("agencies")
}

model AgencyModel {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  profileId String   @unique
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("agency_models")
}

model Profile {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName  String
  slug         String   @unique
  bio          String?  @db.Text
  age          Int?

  country      String
  countryCode  String
  city         String
  citySlug     String

  email        String?
  phone        String?
  instagram    String?
  twitter      String?
  website      String?

  availability AvailabilityStatus @default(AVAILABLE)
  listingTier  ListingTier        @default(FREE)
  isActive     Boolean            @default(true)
  isVerified   Boolean            @default(false)

  profileImageUrl String?
  images          ProfileImage[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  premiumExpiresAt DateTime?

  favorites    Favorite[]
  agencyModel  AgencyModel?

  @@index([country, city])
  @@index([countryCode, citySlug])
  @@index([listingTier, createdAt])
  @@index([slug])
  @@map("profiles")
}

model ProfileImage {
  id         String   @id @default(cuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  url        String
  key        String
  order      Int      @default(0)
  isMain     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("profile_images")
}

model VerificationRequest {
  id        String             @id @default(cuid())
  userId    String             @unique
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  status    VerificationStatus @default(PENDING)

  idImageKey    String?
  videoKey      String?

  adminNotes    String?  @db.Text
  reviewedAt    DateTime?
  reviewedBy    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("verification_requests")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, profileId])
  @@map("favorites")
}

model PremiumOrder {
  id          String   @id @default(cuid())
  profileId   String?
  agencyId    String?
  amount      Int
  currency    String   @default("USD")
  status      String   @default("pending")
  orderType   String   @default("model_premium")
  stripePaymentIntentId String?
  durationDays Int     @default(30)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("premium_orders")
}
