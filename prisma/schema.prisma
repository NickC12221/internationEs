generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST      // Regular site visitor / booker
  MODEL
  AGENCY
  ADMIN
}

enum VerificationStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  TRAVELING
  BUSY
}

enum ListingTier {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(GUEST)
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile             Profile?
  agency              Agency?
  verificationRequest VerificationRequest?
  favorites           Favorite[]           @relation("UserFavorites")

  // Messaging
  sentMessages        Message[]            @relation("SentMessages")
  conversations       ConversationMember[]

  // Bookings
  bookingsAsGuest     Booking[]            @relation("GuestBookings")

  // Reviews
  reviewsWritten      Review[]

  // Notifications
  notifications       Notification[]

  @@map("users")
}

// ─── Conversations & Messages ─────────────────────────────────────────────────

model Conversation {
  id          String   @id @default(cuid())
  subject     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     ConversationMember[]
  messages    Message[]

  // Context (optional - links to a booking or profile)
  profileId   String?
  bookingId   String?

  @@map("conversations")
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content        String       @db.Text
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

model Booking {
  id          String        @id @default(cuid())
  profileId   String
  profile     Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  guestId     String
  guest       User          @relation("GuestBookings", fields: [guestId], references: [id], onDelete: Cascade)

  date        DateTime
  duration    Int           // hours
  message     String?       @db.Text
  contactName String
  contactEmail String
  contactPhone String?

  status      BookingStatus @default(PENDING)
  totalAmount Int?          // in cents
  currency    String        @default("USD")

  adminNotes  String?       @db.Text
  respondedAt DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  review      Review?

  @@index([profileId, status])
  @@index([guestId])
  @@map("bookings")
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  rating    Int      // 1-5
  content   String   @db.Text
  isVisible Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@map("reviews")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // new_message, new_booking, booking_accepted, booking_rejected, new_review
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Profiles ─────────────────────────────────────────────────────────────────

model Profile {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName  String
  slug         String   @unique
  bio          String?  @db.Text
  age          Int?

  country      String
  countryCode  String
  city         String
  citySlug     String

  phone        String?
  instagram    String?
  twitter      String?
  website      String?

  availability AvailabilityStatus @default(AVAILABLE)
  listingTier  ListingTier        @default(FREE)
  isActive     Boolean            @default(true)
  isVerified   Boolean            @default(false)

  profileImageUrl String?
  images          ProfileImage[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  premiumExpiresAt DateTime?

  favorites    Favorite[]
  agencyModel  AgencyModel?
  bookings     Booking[]
  reviews      Review[]

  @@index([country, city])
  @@index([countryCode, citySlug])
  @@index([listingTier, createdAt])
  @@index([slug])
  @@map("profiles")
}

model ProfileImage {
  id         String   @id @default(cuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  url        String
  key        String
  order      Int      @default(0)
  isMain     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("profile_images")
}

// ─── Agencies ────────────────────────────────────────────────────────────────

model Agency {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  slug        String   @unique
  bio         String?  @db.Text
  website     String?
  instagram   String?
  phone       String?
  email       String?

  country     String
  countryCode String
  city        String
  citySlug    String

  logoUrl     String?

  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  subscriptionExpiresAt DateTime?

  isPremium   Boolean  @default(false)
  premiumExpiresAt DateTime?

  isActive    Boolean  @default(true)

  models      AgencyModel[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([countryCode, citySlug])
  @@index([isPremium])
  @@map("agencies")
}

model AgencyModel {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  profileId String   @unique
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("agency_models")
}

// ─── Other ────────────────────────────────────────────────────────────────────

model VerificationRequest {
  id        String             @id @default(cuid())
  userId    String             @unique
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    VerificationStatus @default(PENDING)
  idImageKey    String?
  videoKey      String?
  adminNotes    String?  @db.Text
  reviewedAt    DateTime?
  reviewedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("verification_requests")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, profileId])
  @@map("favorites")
}

model PremiumOrder {
  id          String   @id @default(cuid())
  profileId   String?
  agencyId    String?
  amount      Int
  currency    String   @default("USD")
  status      String   @default("pending")
  orderType   String   @default("model_premium")
  stripePaymentIntentId String?
  durationDays Int     @default(30)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("premium_orders")
}
